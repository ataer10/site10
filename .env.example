# ----------------------------------------------------------------------
# Birtek — ortam değişkenleri. Bu dosyayı `.env.local` olarak kopyalayın.
# Hiçbiri tanımlı değilse site, seed verisiyle (lib/data/seed.ts) çalışır.
# ----------------------------------------------------------------------

# Supabase (Faz 2+). Proje ayarları > API'den alın.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# E-posta gönderimi
# Birincil yöntem: Admin Panel > E-posta (SMTP) — buradan yönetilir (önerilen).
# Aşağıdakiler yalnız admin'de SMTP tanımlı DEĞİLSE devreye giren YEDEK ayarlardır.
COMPANY_EMAIL=                 # admin firma e-postası boşsa teklif bildirimi buraya
# Yedek SMTP (admin panelde tanımlıysa gerekmez):
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false              # 465 için true
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=                    # ör. "Birtek <teklif@birtek.com.tr>"
# Resend (opsiyonel, SMTP yoksa son çare)
RESEND_API_KEY=

# Admin erişim beyaz listesi — sadece bu e-postalar /admin'e girebilir (virgülle ayır)
ADMIN_EMAILS=info@firma.com

# Genel
NEXT_PUBLIC_WHATSAPP_NUMBER=905000000000
# SEO: canonical/sitemap/OG için kök URL (PROD'da gerçek domain!)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# SEO doğrulama (opsiyonel): Google Search Console meta token'ı
GOOGLE_SITE_VERIFICATION=
