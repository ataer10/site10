# ----------------------------------------------------------------------
# Birtek — ortam değişkenleri. Bu dosyayı `.env.local` olarak kopyalayın.
# Hiçbiri tanımlı değilse site, seed verisiyle (lib/data/seed.ts) çalışır.
# ----------------------------------------------------------------------

# Supabase (Faz 2+). Proje ayarları > API'den alın.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Resend (Faz 3+ e-postalar)
RESEND_API_KEY=
COMPANY_EMAIL=

# Genel
NEXT_PUBLIC_WHATSAPP_NUMBER=905000000000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
